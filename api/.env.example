# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=your-mongodb-uri

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRATION=7d
JWT_RESET_SECRET=your_jwt_reset_secret_key_here
JWT_RESET_PASSWORD_SECRET=your_jwt_reset_password_secret_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# External API Configuration
ODDS_API_KEY=your_odds_api_key_here

# Mollie Payment Configuration
MOLLIE_API_KEY=your_mollie_api_key_here
MOLLIE_WEBHOOK_URL=http://localhost:3000/payment/webhook
MOLLIE_REDIRECT_URL=http://localhost:5173/payment/return

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
